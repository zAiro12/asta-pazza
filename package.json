    "pusher-js": "^8.4.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^2.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.10",
    "autoprefixer": "^10",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
