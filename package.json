{
  "name": "asta-pazza",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
